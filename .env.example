# Copy to .env for local or Docker Compose runs.
# Do not commit real API keys.
# Deterministic/offline validation commands do not require provider credentials.

ZYFANGJI_DB_PATH=var/metadata/knowledge.db
ZYFANGJI_QDRANT_URL=http://qdrant:6333
ZYFANGJI_QDRANT_COLLECTION_PREFIX=zyfangji_entries
ZYFANGJI_QDRANT_ALIAS=zyfangji_entries_active
ZYFANGJI_EMBEDDING_PROVIDER=bge_m3
ZYFANGJI_EMBEDDING_MODEL_ID=BAAI/bge-m3
ZYFANGJI_EMBEDDING_VECTOR_SIZE=1024
ZYFANGJI_EMBEDDING_ENDPOINT_URL=
ZYFANGJI_EMBEDDING_API_KEY=
ZYFANGJI_EMBEDDING_TIMEOUT_SECONDS=30
ZYFANGJI_BM25_INDEX_ROOT=var/indexes/bm25
ZYFANGJI_SEARCH_DEFAULT_TOPK=10
ZYFANGJI_SEARCH_MAX_TOPK=50
ZYFANGJI_RECALL_TOPK=50
ZYFANGJI_FUSION_STRATEGY=rrf
ZYFANGJI_RRF_K=60
ZYFANGJI_RERANKER_PROVIDER=bge
ZYFANGJI_RERANKER_MODEL_ID=BAAI/bge-reranker-v2-m3
ZYFANGJI_RERANKER_REQUIRED=true
ZYFANGJI_API_TITLE=Zyfangji Retrieval Service

